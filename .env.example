# Generate with: npx auth secret
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string

# Optional: override database location (default: ./data/script-wars.db)
# DATABASE_URL=./data/script-wars.db

# Optional: set base URL for auth callbacks
# BETTER_AUTH_URL=http://localhost:5173

# Email verification via Resend (https://resend.com)
# Required in production for email verification
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# EMAIL_FROM=Script Wars <noreply@yourdomain.com>

# Cloudflare Turnstile CAPTCHA (https://dash.cloudflare.com/turnstile)
# PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# Admin secret for triggering tournaments manually
# ADMIN_SECRET=your-secret-here
